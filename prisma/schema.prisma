generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanoUsuario {
  FREE
  PREMIUM
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  password      String
  emailVerified DateTime?
  image         String?
  plano         PlanoUsuario  @default(FREE)
  planoExpiraEm DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  compromissos  Compromisso[]
  atividades    Atividade[]
  
  @@map("users")
}

model Compromisso {
  id          String    @id @default(cuid())
  titulo      String
  descricao   String?
  data        DateTime
  horaInicio  String
  horaFim     String?
  categoria   String?
  cor         String    @default("#8B5CF6")
  concluido   Boolean   @default(false)
  
  isRecorrente         Boolean   @default(false)
  tipoRecorrencia      String?
  intervaloRecorrencia Int?      @default(1)
  dataFimRecorrencia   DateTime?
  recorrenciaGrupoId   String?
  recorrenciaInstancia Int?      @default(1)
  
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  @@map("compromissos")
  @@index([userId, data])
  @@index([recorrenciaGrupoId])
}

model Atividade {
  id          String   @id @default(cuid())
  tipo        String
  titulo      String
  descricao   String?
  metadata    Json?
  icone       String   @default("activity")
  cor         String   @default("#8B5CF6")
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@map("atividades")
  @@index([userId, createdAt(sort: Desc)])
}