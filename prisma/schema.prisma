generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlanoUsuario {
  FREE
  PREMIUM
}

enum TipoConta {
  CORRENTE
  POUPANCA
  INVESTIMENTO
}

enum TipoTransacao {
  RECEITA
  DESPESA
}

enum StatusObjetivo {
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

enum TipoMidia {
  LIVRO
  FILME
}

enum StatusLeitura {
  PROXIMO
  EM_ANDAMENTO
  PAUSADO
  CONCLUIDO
}

enum FonteLivro {
  EMPRESTADO
  FISICO
  KINDLE
  DIGITAL
}

enum StatusViagem {
  PLANEJADA
  EM_ANDAMENTO
  CONCLUIDA
  CANCELADA
}

enum PropostoViagem {
  LAZER
  TRABALHO
  ESTUDO
  OUTRO
}

enum TipoTransporte {
  AVIAO
  CARRO
  ONIBUS
  TREM
  TAXI
  UBER
  OUTRO
}

enum CategoriaAtividade {
  TURISMO
  TRABALHO
  LAZER
  ALIMENTACAO
  OUTRO
}

enum TipoDocumento {
  PASSAPORTE
  VISTO
  RG
  CNH
  SEGURO_VIAGEM
  RESERVA
  OUTRO
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  password      String
  emailVerified DateTime?
  image         String?
  plano         PlanoUsuario  @default(FREE)
  planoExpiraEm DateTime?

  // Integração Google Calendar
  googleAccessToken           String?     @db.Text
  googleRefreshToken          String?     @db.Text
  googleTokenExpiry           DateTime?
  googleCalendarChannelId     String?     @unique
  googleCalendarResourceId    String?
  googleCalendarWatchExpiration DateTime?

  // Integração Stripe
  stripeCustomerId            String?     @unique
  stripeSubscriptionId        String?     @unique
  stripeSubscriptionStatus    String?     // active, canceled, past_due, etc
  stripePriceId               String?     // ID do plano (mensal ou anual)
  stripeCurrentPeriodEnd      DateTime?   // Fim do período de cobrança

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  compromissos       Compromisso[]
  atividades         Atividade[]
  contasBancarias    ContaBancaria[]
  cartoes            Cartao[]
  categorias         Categoria[]
  transacoes         Transacao[]
  objetivosFinanceiros ObjetivoFinanceiro[]
  cursos             Curso[]
  anotacoes          Anotacao[]
  midias             Midia[]
  citacoes           Citacao[]
  viagens            Viagem[]
  documentosViagem   DocumentoViagem[]

  @@map("users")
}

model Compromisso {
  id          String    @id @default(cuid())
  titulo      String
  descricao   String?
  data        DateTime
  horaInicio  String
  horaFim     String?
  categoria   String?
  cor         String    @default("#8B5CF6")
  concluido   Boolean   @default(false)

  isRecorrente         Boolean   @default(false)
  tipoRecorrencia      String?
  intervaloRecorrencia Int?      @default(1)
  dataFimRecorrencia   DateTime?
  recorrenciaGrupoId   String?
  recorrenciaInstancia Int?      @default(1)

  // Integração Google Calendar
  syncWithGoogle       Boolean   @default(false)
  googleEventId        String?   @unique

  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("compromissos")
  @@index([userId, data])
  @@index([recorrenciaGrupoId])
  @@index([googleEventId])
}

model Atividade {
  id          String   @id @default(cuid())
  tipo        String
  titulo      String
  descricao   String?
  metadata    Json?
  icone       String   @default("activity")
  cor         String   @default("#8B5CF6")
  
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  
  @@map("atividades")
  @@index([userId, createdAt(sort: Desc)])
}

model ContaBancaria {
  id            String     @id @default(cuid())
  nome          String
  tipo          TipoConta  @default(CORRENTE)
  banco         String?
  saldoInicial  Decimal    @default(0) @db.Decimal(15, 2)
  saldoAtual    Decimal    @default(0) @db.Decimal(15, 2)
  cor           String     @default("#10B981")
  icone         String     @default("wallet")
  ativa         Boolean    @default(true)
  
  userId        String
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transacoes    Transacao[]
  
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  @@map("contas_bancarias")
  @@index([userId, ativa])
}

model Cartao {
  id              String    @id @default(cuid())
  nome            String
  bandeira        String?
  ultimosDigitos  String?
  limite          Decimal?  @db.Decimal(15, 2)
  diaVencimento   Int?
  diaFechamento   Int?
  cor             String    @default("#3B82F6")
  icone           String    @default("credit-card")
  ativo           Boolean   @default(true)
  
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transacoes      Transacao[]
  
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  @@map("cartoes")
  @@index([userId, ativo])
}

model Categoria {
  id              String         @id @default(cuid())
  nome            String
  tipo            TipoTransacao
  cor             String         @default("#8B5CF6")
  icone           String         @default("tag")
  
  categoriaPaiId  String?
  categoriaPai    Categoria?     @relation("SubcategoriaRelacao", fields: [categoriaPaiId], references: [id], onDelete: Cascade)
  subcategorias   Categoria[]    @relation("SubcategoriaRelacao")
  
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  transacoes      Transacao[]
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  
  @@map("categorias")
  @@index([userId, tipo])
  @@unique([userId, nome, tipo])
}

model Transacao {
  id                String         @id @default(cuid())
  descricao         String
  valor             Decimal        @db.Decimal(15, 2)
  data              DateTime
  tipo              TipoTransacao
  observacoes       String?

  isFixa            Boolean        @default(false)

  isParcela         Boolean        @default(false)
  parcelaNumero     Int?
  parcelaTotais     Int?
  grupoParcelaId    String?

  categoriaId       String?
  categoria         Categoria?     @relation(fields: [categoriaId], references: [id], onDelete: SetNull)

  // IMPORTANTE: Conta bancária é OBRIGATÓRIA em toda transação
  // Cartão é apenas informação adicional opcional (ex: compra no cartão será debitada da conta)
  contaBancariaId   String
  contaBancaria     ContaBancaria  @relation(fields: [contaBancariaId], references: [id], onDelete: Restrict)

  cartaoId          String?
  cartao            Cartao?        @relation(fields: [cartaoId], references: [id], onDelete: SetNull)

  objetivoId        String?
  objetivo          ObjetivoFinanceiro? @relation(fields: [objetivoId], references: [id], onDelete: SetNull)

  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@map("transacoes")
  @@index([userId, data(sort: Desc)])
  @@index([userId, tipo, data])
  @@index([grupoParcelaId])
  @@index([categoriaId])
  @@index([contaBancariaId])
  @@index([cartaoId])
}

model ObjetivoFinanceiro {
  id                    String         @id @default(cuid())
  nome                  String
  descricao             String?
  valorMeta             Decimal        @db.Decimal(15, 2)
  valorAtual            Decimal        @default(0) @db.Decimal(15, 2)
  dataInicio            DateTime       @default(now())
  dataMeta              DateTime?

  isReservaEmergencia   Boolean        @default(false)
  cor                   String         @default("#F59E0B")
  icone                 String         @default("target")
  status                StatusObjetivo @default(EM_ANDAMENTO)

  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  transacoes            Transacao[]

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@map("objetivos_financeiros")
  @@index([userId, status])
}

model Curso {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  cor         String   @default("#8B5CF6")
  icone       String   @default("book-open")
  ativo       Boolean  @default(true)
  ordem       Int      @default(0)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  modulos     Modulo[]
  anotacoes   Anotacao[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cursos")
  @@index([userId, ativo])
}

model Modulo {
  id          String   @id @default(cuid())
  nome        String
  descricao   String?
  ordem       Int      @default(0)

  cursoId     String
  curso       Curso    @relation(fields: [cursoId], references: [id], onDelete: Cascade)

  paginas     Pagina[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("modulos")
  @@index([cursoId, ordem])
}

model Pagina {
  id          String   @id @default(cuid())
  titulo      String
  conteudo    String   @db.Text
  ordem       Int      @default(0)

  moduloId    String
  modulo      Modulo   @relation(fields: [moduloId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("paginas")
  @@index([moduloId, ordem])
}

model Anotacao {
  id          String   @id @default(cuid())
  titulo      String
  conteudo    String   @db.Text
  cor         String   @default("#FBBF24")

  cursoId     String?
  curso       Curso?   @relation(fields: [cursoId], references: [id], onDelete: SetNull)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("anotacoes")
  @@index([userId, createdAt(sort: Desc)])
  @@index([cursoId])
}

model Midia {
  id                    String         @id @default(cuid())
  tipo                  TipoMidia
  titulo                String
  capa                  String?
  cor                   String         @default("#8B5CF6")

  // Campos específicos de livro
  autor                 String?
  editora               String?
  genero                String?
  fonte                 FonteLivro?

  // Campos específicos de filme
  diretor               String?
  duracao               Int?
  anoLancamento         Int?

  // Campos comuns
  idioma                String?
  status                StatusLeitura  @default(PROXIMO)
  nota                  Int?
  dataInicio            DateTime?
  dataConclusao         DateTime?

  // Resenha gerada por IA
  resenhaGeradaIA       String?        @db.Text

  // Reflexões e aprendizados
  impressoesIniciais    String?        @db.Text
  principaisAprendizados String?       @db.Text
  trechosMemoraveis     String?        @db.Text
  reflexao              String?        @db.Text
  aprendizadosPraticos  String?        @db.Text
  consideracoesFinais   String?        @db.Text

  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  citacoes              Citacao[]

  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@map("midias")
  @@index([userId, tipo, status])
  @@index([userId, createdAt(sort: Desc)])
}

model Citacao {
  id          String   @id @default(cuid())
  texto       String   @db.Text
  autor       String?
  pagina      String?
  destaque    Boolean  @default(false)

  midiaId     String?
  midia       Midia?   @relation(fields: [midiaId], references: [id], onDelete: Cascade)

  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("citacoes")
  @@index([userId, destaque])
  @@index([midiaId])
  @@index([userId, createdAt(sort: Desc)])
}

model Waitlist {
  id        String   @id @default(cuid())
  email     String   @unique
  nome      String?
  interesse String?  // Qual módulo mais interessa
  createdAt DateTime @default(now())

  @@map("waitlist")
  @@index([createdAt(sort: Desc)])
}

model VerificationToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([email, token])
  @@index([email])
  @@index([token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id         String   @id @default(cuid())
  email      String
  token      String   @unique
  expires    DateTime
  createdAt  DateTime @default(now())

  @@unique([email, token])
  @@index([email])
  @@index([token])
  @@map("password_reset_tokens")
}

// ============================================
// MODELOS DE GERENCIAMENTO DE VIAGENS
// ============================================

model Viagem {
  id                String          @id @default(cuid())
  nome              String
  descricao         String?         @db.Text
  proposito         PropostoViagem  @default(LAZER)
  status            StatusViagem    @default(PLANEJADA)

  // Datas principais
  dataInicio        DateTime
  dataFim           DateTime

  // Informações gerais
  orcamentoTotal    Decimal?        @db.Decimal(15, 2)
  notasGerais       String?         @db.Text

  // Avaliação e memórias
  avaliacaoGeral    Int?            // 1-5 estrelas
  diario            String?         @db.Text

  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  destinos          DestinoViagem[]
  transportes       TransporteViagem[]
  hospedagens       HospedagemViagem[]
  atividades        AtividadeViagem[]
  despesas          DespesaViagem[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("viagens")
  @@index([userId, status])
  @@index([userId, dataInicio])
}

model DestinoViagem {
  id                String          @id @default(cuid())
  ordem             Int             @default(0)

  // Informações do destino
  nome              String
  cidade            String
  pais              String
  endereco          String?
  latitude          Float?
  longitude         Float?

  // Datas no destino
  dataChegada       DateTime
  dataSaida         DateTime

  // Informações do destino
  fusoHorario       String?
  idioma            String?
  moeda             String?
  voltagem          String?
  tomada            String?

  // Informações culturais e práticas
  costumes          String?         @db.Text
  gorjetas          String?
  emergencia        String?
  frasesBasicas     String?         @db.Text

  // Clima
  temperaturaMed    String?
  previsaoClima     String?

  viagemId          String
  viagem            Viagem          @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  locaisSalvos      LocalSalvo[]

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("destinos_viagem")
  @@index([viagemId, ordem])
}

model LocalSalvo {
  id                String          @id @default(cuid())
  nome              String
  tipo              String          // restaurante, atração, hospital, farmácia, etc
  endereco          String?
  latitude          Float?
  longitude         Float?
  telefone          String?
  notas             String?         @db.Text
  favorito          Boolean         @default(false)

  destinoId         String
  destino           DestinoViagem   @relation(fields: [destinoId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("locais_salvos")
  @@index([destinoId, favorito])
}

model TransporteViagem {
  id                String          @id @default(cuid())
  tipo              TipoTransporte

  // Informações gerais
  descricao         String?
  dataHora          DateTime
  origem            String?
  destino           String?

  // Informações de voo
  companhia         String?
  numeroVoo         String?
  assento           String?
  horarioEmbarque   DateTime?
  portaoEmbarque    String?
  conexao           String?
  horarioChegada    DateTime?
  codigoReserva     String?

  // Transporte terrestre
  empresa           String?
  placaVeiculo      String?

  // Arquivos
  arquivoUrl        String?         // URL do cartão de embarque ou comprovante

  // Rotas e tempo
  rotaUrl           String?
  tempoEstimado     String?

  notas             String?         @db.Text

  viagemId          String
  viagem            Viagem          @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("transportes_viagem")
  @@index([viagemId, dataHora])
}

model HospedagemViagem {
  id                String          @id @default(cuid())
  tipo              String          @default("hotel") // hotel, hostel, airbnb, etc
  nome              String

  // Datas
  checkIn           DateTime
  checkOut          DateTime

  // Localização
  endereco          String?
  cidade            String?
  latitude          Float?
  longitude         Float?

  // Contato e reserva
  telefone          String?
  email             String?
  codigoReserva     String?
  website           String?

  // Arquivos
  comprovanteUrl    String?

  // Avaliação
  avaliacaoPessoal  Int?            // 1-5 estrelas
  notas             String?         @db.Text

  viagemId          String
  viagem            Viagem          @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("hospedagens_viagem")
  @@index([viagemId, checkIn])
}

model AtividadeViagem {
  id                String              @id @default(cuid())
  titulo            String
  descricao         String?             @db.Text

  // Data e horário
  data              DateTime
  horaInicio        String?
  horaFim           String?

  // Local
  local             String?
  endereco          String?
  latitude          Float?
  longitude         Float?

  // Categoria e prioridade
  categoria         CategoriaAtividade  @default(TURISMO)
  prioridade        Int                 @default(0) // 0-5

  // Status
  concluida         Boolean             @default(false)
  favorita          Boolean             @default(false)

  // Tempo
  tempoEstimado     String?

  // Checklist
  checklist         Json?               // Array de { item: string, concluido: boolean }

  notas             String?             @db.Text

  viagemId          String
  viagem            Viagem              @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@map("atividades_viagem")
  @@index([viagemId, data])
  @@index([viagemId, favorita])
}

model DespesaViagem {
  id                String          @id @default(cuid())
  descricao         String
  valor             Decimal         @db.Decimal(15, 2)
  moeda             String          @default("BRL")
  valorConvertido   Decimal?        @db.Decimal(15, 2) // Valor em BRL

  data              DateTime
  categoria         String          // transporte, hospedagem, alimentacao, passeios, compras

  formaPagamento    String?         // dinheiro, cartao, pix

  notas             String?

  viagemId          String
  viagem            Viagem          @relation(fields: [viagemId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("despesas_viagem")
  @@index([viagemId, data])
  @@index([viagemId, categoria])
}

model DocumentoViagem {
  id                String          @id @default(cuid())
  tipo              TipoDocumento
  nome              String
  numero            String?

  dataEmissao       DateTime?
  dataValidade      DateTime?

  arquivoUrl        String?
  notas             String?         @db.Text

  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@map("documentos_viagem")
  @@index([userId, tipo])
  @@index([userId, dataValidade])
}